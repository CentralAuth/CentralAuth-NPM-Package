{
  "name": "centralauth",
  "version": "1.0.0",
  "description": "Official package for CentralAuth",
  "type": "module",
  "exports": {
    "./client": {
      "types": "./src/client.d.ts",
      "import": "./src/client.js",
      "require": "./dist/cjs/src/client.js",
      "default": "./src/client.js"
    },
    "./server": {
      "types": "./src/server.d.ts",
      "import": "./src/server.js",
      "require": "./dist/cjs/src/server.js",
      "default": "./src/server.js"
    },
    "./native": {
      "types": "./src/native.d.ts",
      "import": "./src/native.js",
      "require": "./dist/cjs/src/native.js",
      "default": "./src/native.js"
    },
    "./types": {
      "types": "./src/types.d.ts",
      "import": "./src/types.js",
      "require": "./dist/cjs/src/types.js",
      "default": "./src/types.js"
    },
    "./react.types": {
      "types": "./src/react.types.d.ts",
      "import": "./src/react.types.js",
      "require": "./dist/cjs/src/react.types.js",
      "default": "./src/react.types.js"
    },
    "./openapi-ts.config": {
      "types": "./openapi-ts.config.d.ts",
      "import": "./openapi-ts.config.js",
      "require": "./dist/cjs/openapi-ts.config.js",
      "default": "./openapi-ts.config.js"
    }
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && rm -rf dist/cjs && openapi-ts && npx tsc && npm run build:cjs",
    "build:cjs": "mkdir -p dist/cjs && printf '{\"type\":\"commonjs\"}\n' > dist/cjs/package.json && npx tsc -p tsconfig.cjs.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CentralAuth/CentralAuth-NPM-Package"
  },
  "homepage": "https://github.com/CentralAuth/CentralAuth-NPM-Package",
  "keywords": [
    "Authentication",
    "CentralAuth",
    "OAuth",
    "JWT"
  ],
  "author": "West IT",
  "license": "MIT",
  "dependencies": {
    "@hey-api/openapi-ts": "^0.96.0",
    "axios": "^1.15.0",
    "axios-cache-interceptor": "^1.12.0",
    "jose": "^6.1.3"
  },
  "peerDependencies": {
    "expo-crypto": "^55.0.0",
    "expo-device": "^55.0.0",
    "expo-linking": "^55.0.0",
    "expo-secure-store": "^55.0.0",
    "expo-web-browser": "^55.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "swr": "^2.4.0"
  },
  "peerDependenciesMeta": {
    "expo-crypto": {
      "optional": true
    },
    "expo-device": {
      "optional": true
    },
    "expo-linking": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-web-browser": {
      "optional": true
    },
    "swr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "expo-crypto": "^55.0.10",
    "expo-device": "^55.0.10",
    "expo-linking": "^55.0.8",
    "expo-secure-store": "^55.0.9",
    "expo-web-browser": "^55.0.10",
    "swr": "^2.4.0",
    "typescript": "^6.0.2"
  }
}
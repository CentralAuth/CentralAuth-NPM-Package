{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist/cjs",
    "sourceMap": false,
    "declaration": false,
    "incremental": false
  },
  "include": [
    "src/*.tsx",
    "./*.ts"
  ],
  "exclude": [
    "node_modules",
    "api"
  ]
}